# AI Marketing Tools — Environment Variables
# Copy this to .env and fill in your keys

# REQUIRED: Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Medium (get from https://medium.com/me/settings → Integration tokens)
MEDIUM_TOKEN=your_medium_token_here

# OPTIONAL: DEV.to (get from https://dev.to/settings/extensions → DEV Community API Keys)
DEVTO_API_KEY=your_devto_api_key_here

# OPTIONAL: Hashnode (get from https://hashnode.com/settings/developer → Personal Access Token)
HASHNODE_TOKEN=your_hashnode_token_here
HASHNODE_PUBLICATION_ID=your_publication_id_here
