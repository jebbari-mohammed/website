# Gemini API Keys (rotate for rate limit management)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=optional_second_key
GEMINI_API_KEY_3=optional_third_key

# YouTube Upload (run youtube-auth.mjs to generate)
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-your_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here
